{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "npx tsc --noEmit || echo '{\"decision\":\"block\",\"reason\":\"Typ-Fehler gefunden. npm run typecheck zum Debuggen.\"}'",
            "timeout": 30,
            "statusMessage": "Typecheck..."
          }
        ]
      }
    ]
  }
}
