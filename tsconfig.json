{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleDetection": "auto",
    "skipLibCheck": true
  },
  "include": [
    "src/types.d.ts",
    "src/core/**/*.js",
    "src/world/**/*.js",
    "src/infra/**/*.js"
  ],
  "exclude": [
    "src/infra/worker.js",
    "src/infra/gemini-voice-worker.js",
    "sw.js",
    "node_modules"
  ]
}
